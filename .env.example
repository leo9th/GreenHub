# GreenHub web — copy to `.env` and replace placeholders (never commit `.env`).

# Set to `true` to show Facebook login alongside Google when OAuth is configured in Supabase.
VITE_ENABLE_FACEBOOK_LOGIN=false

# MapLibre style URL for buyer delivery tracking maps (falls back in code if unset).
VITE_MAPLIBRE_STYLE_URL=https://example.com/your-style.json

# Mapbox GL token for bookGo / ride booking map UI (placeholder if unused).
VITE_MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN

# Paystack public key for checkout and seller advertise/boost flows (`pk_test_...` or `pk_live_...`).
VITE_PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_ME

# Optional Sentry browser DSN for error reporting (use empty string to disable).
VITE_SENTRY_DSN=

# Optional fraction 0–1 for Sentry performance traces (only used when `VITE_SENTRY_DSN` is set).
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Supabase project URL (Dashboard → Project Settings → API).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anonymous/public key (Dashboard → Project Settings → API — safe for browser clients).
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Public site URL for auth redirects / reset-password when it differs from localhost (production origin).
VITE_SITE_URL=http://localhost:5173
